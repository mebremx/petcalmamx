[
  {
    "name": "theme_info",
    "theme_name": "Pet Calma MX",
    "theme_version": "1.0.0",
    "theme_author": "Pet Calma MX",
    "theme_documentation_url": "https://shopify.dev",
    "theme_support_url": "https://shopify.dev"
  },
  {
    "name": "Logo y branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo de la tienda"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 220,
        "step": 5,
        "unit": "px",
        "label": "Ancho del logo (desktop)",
        "default": 120
      },
      {
        "type": "checkbox",
        "id": "show_logo_text",
        "label": "Mostrar nombre de la marca junto al logo",
        "default": false
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colores",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Verde teal principal",
        "default": "#2A9D8F"
      },
      {
        "type": "color",
        "id": "color_primary_dark",
        "label": "Verde teal oscuro (hover, headings)",
        "default": "#1F6F65"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Coral suave (acento)",
        "default": "#F4A28C"
      },
      {
        "type": "color",
        "id": "color_cream",
        "label": "Crema cálido (fondos suaves)",
        "default": "#FAF5EC"
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Fondo de la página",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Color de texto principal",
        "default": "#1F3A38"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Texto secundario",
        "default": "#6B7C7A"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Bordes",
        "default": "#E7E2D6"
      }
    ]
  },
  {
    "name": "Tipografía",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Tipografía de títulos",
        "default": "poppins_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Tipografía de cuerpo",
        "default": "poppins_n4"
      }
    ]
  },
  {
    "name": "Anuncio superior",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_announcement",
        "label": "Mostrar barra de anuncios",
        "default": true
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Texto del anuncio",
        "default": "🐾 Envío GRATIS en pedidos +$499 MXN — entrega en 3-5 días"
      }
    ]
  },
  {
    "name": "Redes sociales",
    "settings": [
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_whatsapp",
        "label": "WhatsApp (link wa.me)"
      }
    ]
  }
]
