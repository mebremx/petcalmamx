<section class="section section--white benefits">
  <div class="container">
    <header class="benefits__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="benefits__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="benefits__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    <div class="benefits__grid">
      {%- for block in section.blocks -%}
        <article class="benefit-card" {{ block.shopify_attributes }}>
          <span class="benefit-card__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- when 'shower' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v6a8 8 0 0 0 16 0V4"/><line x1="8" y1="14" x2="8" y2="20"/><line x1="12" y1="14" x2="12" y2="22"/><line x1="16" y1="14" x2="16" y2="20"/></svg>
              {%- when 'brain' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4 4 4 0 0 0-4 4 4 4 0 0 0 1 6.65A4 4 0 0 0 8 22a4 4 0 0 0 4-2 4 4 0 0 0 4 2 4 4 0 0 0 3-5.35A4 4 0 0 0 20 10a4 4 0 0 0-4-4 4 4 0 0 0-4-4z"/></svg>
              {%- when 'sparkles' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3z"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'paw' -%}
                <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5.5" cy="9.5" r="2"/><circle cx="9.5" cy="5.5" r="2"/><circle cx="14.5" cy="5.5" r="2"/><circle cx="18.5" cy="9.5" r="2"/><path d="M12 11c-3 0-6 3-6 6 0 2 1.5 3 3 3 1 0 1.5-.5 3-.5s2 .5 3 .5c1.5 0 3-1 3-3 0-3-3-6-6-6z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            {%- endcase -%}
          </span>
          <h3 class="benefit-card__title">{{ block.settings.title }}</h3>
          <p class="benefit-card__text">{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beneficios",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Por qué Pet Calma"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Calma, entretenimiento y bienestar para tu mascota"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Diseñado para resolver los momentos más estresantes del día con una experiencia que tu mascota va a amar."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "heart", "label": "Corazón (ansiedad)" },
            { "value": "shower", "label": "Regadera (baño)" },
            { "value": "brain", "label": "Cerebro (estimulación)" },
            { "value": "sparkles", "label": "Brillos (limpieza)" },
            { "value": "shield", "label": "Escudo (seguridad)" },
            { "value": "paw", "label": "Huella" }
          ],
          "default": "heart"
        },
        { "type": "text", "id": "title", "label": "Título", "default": "Beneficio" },
        { "type": "textarea", "id": "text", "label": "Descripción", "default": "Texto descriptivo del beneficio." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "heart", "title": "Reduce la ansiedad", "text": "El movimiento de lamer libera endorfinas que calman a tu mascota de forma natural." } },
        { "type": "benefit", "settings": { "icon": "shower", "title": "Ideal para baño y uñas", "text": "Se pega a la pared con succión. Tu perro se queda quieto mientras lo bañas o le cortas las uñas." } },
        { "type": "benefit", "settings": { "icon": "brain", "title": "Estimula la mente", "text": "Las texturas distintas mantienen a tu mascota concentrada y reducen comportamiento destructivo." } },
        { "type": "benefit", "settings": { "icon": "sparkles", "title": "Fácil de limpiar", "text": "Apto para lavavajillas. Material de silicona libre de BPA, seguro para mascotas." } }
      ]
    }
  ]
}
{% endschema %}
