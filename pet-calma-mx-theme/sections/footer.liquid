<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 240 | image_tag:
            loading: 'lazy',
            alt: shop.name,
            style: 'height:56px; width:auto;'
          }}
        {%- else -%}
          <h3 style="color:#fff; margin:0 0 1rem;">{{ shop.name }}</h3>
        {%- endif -%}
        <p>{{ section.settings.tagline }}</p>

        <div class="social-links">
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.79a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.22z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_whatsapp != blank -%}
            <a href="{{ settings.social_whatsapp }}" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1l-.9 1.1c-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.5-.6c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 4.9 4.4 2.9 1.2 2.9.8 3.4.8.5 0 1.6-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.2-.2-.4-.3-.7-.4zM12 2C6.48 2 2 6.48 2 12c0 1.78.47 3.46 1.29 4.91L2 22l5.25-1.38C8.66 21.5 10.27 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'links' -%}
          <div {{ block.shopify_attributes }}>
            <h4 class="footer__title">{{ block.settings.heading }}</h4>
            <ul class="footer__links">
              {%- if block.settings.menu != blank -%}
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
        {%- if block.type == 'text' -%}
          <div {{ block.shopify_attributes }}>
            <h4 class="footer__title">{{ block.settings.heading }}</h4>
            <p style="color: rgba(255,255,255,.7); font-size:.92rem;">{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.</span>
      <span>{{ section.settings.tagline_bottom }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Descripción de la marca",
      "default": "Menos estrés, más amor. Productos diseñados para mejorar el bienestar de tu mascota y tu tranquilidad."
    },
    {
      "type": "text",
      "id": "tagline_bottom",
      "label": "Texto inferior",
      "default": "Hecho con 🐾 en México"
    }
  ],
  "blocks": [
    {
      "type": "links",
      "name": "Menú de enlaces",
      "settings": [
        { "type": "text", "id": "heading", "label": "Título", "default": "Tienda" },
        { "type": "link_list", "id": "menu", "label": "Menú", "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "Bloque de texto",
      "settings": [
        { "type": "text", "id": "heading", "label": "Título", "default": "Contacto" },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "hola@petcalma.mx\nLun-Vie 9-18hrs" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "links", "settings": { "heading": "Tienda" } },
        { "type": "text", "settings": { "heading": "Contacto", "text": "hola@petcalma.mx\nLun-Vie 9-18hrs" } }
      ]
    }
  ]
}
{% endschema %}
