<section class="hero">
  <div class="container">
    <div class="hero__grid">
      <div class="hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="hero__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        <h1 class="hero__title">
          {{ section.settings.title }}
        </h1>

        <p class="hero__subtitle">{{ section.settings.subtitle }}</p>

        <div class="hero__ctas">
          {%- if section.settings.cta_url != blank -%}
            <a href="{{ section.settings.cta_url }}" class="btn btn--primary btn--lg">
              {{ section.settings.cta_text | default: 'Comprar ahora' }}
            </a>
          {%- endif -%}
          {%- if section.settings.cta_secondary_url != blank -%}
            <a href="{{ section.settings.cta_secondary_url }}" class="btn btn--secondary btn--lg">
              {{ section.settings.cta_secondary_text | default: 'Ver más' }}
            </a>
          {%- endif -%}
        </div>

        <div class="hero__trust">
          {%- if section.settings.trust_1 != blank -%}
            <span class="hero__trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {{ section.settings.trust_1 }}
            </span>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <span class="hero__trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {{ section.settings.trust_2 }}
            </span>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <span class="hero__trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {{ section.settings.trust_3 }}
            </span>
          {%- endif -%}
        </div>
      </div>

      <div class="hero__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '(min-width: 900px) 50vw, 100vw',
            widths: '400, 600, 900, 1200',
            alt: section.settings.image.alt | default: section.settings.title
          }}
        {%- else -%}
          <div style="background: var(--color-cream); width:100%; height:100%; display:flex; align-items:center; justify-content:center; color: var(--color-text-muted);">
            Agrega una imagen del producto
          </div>
        {%- endif -%}

        {%- if section.settings.badge_text != blank -%}
          <div class="hero__badge">
            <span class="hero__badge-dot"></span>
            {{ section.settings.badge_text }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero del producto",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Pet Calma MX"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título principal",
      "default": "Tu mascota más tranquila en minutos"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo emocional",
      "default": "El tapete lamedor que convierte el baño y el corte de uñas en un momento relajante. Menos estrés, más amor."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del producto en uso"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón principal",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace del botón principal"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Texto del botón secundario",
      "default": "Ver cómo funciona"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Enlace del botón secundario"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge flotante sobre imagen",
      "default": "+1,200 mascotas felices"
    },
    {
      "type": "header",
      "content": "Indicadores de confianza"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Punto 1",
      "default": "Envío en 3-5 días"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Punto 2",
      "default": "Pago seguro"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Punto 3",
      "default": "Garantía 30 días"
    }
  ],
  "presets": [{ "name": "Hero del producto" }]
}
{% endschema %}
