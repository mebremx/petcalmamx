<section class="section">
  <div class="container">
    <div class="cta-final">
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.subtitle }}</p>
      {%- if section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="btn btn--accent btn--lg">
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Final",
  "settings": [
    { "type": "text", "id": "title", "label": "Título", "default": "Menos estrés, más amor" },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo", "default": "Únete a más de 1,200 dueños que ya transformaron los momentos más difíciles con sus mascotas en momentos de paz." },
    { "type": "text", "id": "cta_text", "label": "Texto del botón", "default": "Comprar ahora" },
    { "type": "url", "id": "cta_url", "label": "Enlace del botón" }
  ],
  "presets": [{ "name": "CTA Final" }]
}
{% endschema %}
