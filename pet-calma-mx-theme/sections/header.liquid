<header class="header" role="banner">
  <div class="container header__inner">
    <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }} - inicio">
      {%- if settings.logo != blank -%}
        {{ settings.logo | image_url: width: 400 | image_tag:
          loading: 'eager',
          width: settings.logo.width,
          height: settings.logo.height,
          alt: shop.name,
          style: 'height:auto; width:auto; max-height:54px; max-width:' | append: settings.logo_width | append: 'px;'
        }}
      {%- else -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
      {%- if settings.show_logo_text and settings.logo != blank -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <div class="header__actions">
      <a href="{{ routes.cart_url }}" class="header__cart" aria-label="Carrito">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/>
          <circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-badge" data-cart-count>{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "paragraph",
      "content": "El logo se configura desde Configuración del tema → Logo y branding."
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
