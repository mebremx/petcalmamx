<section class="section">
  <div class="container">
    <h1 style="color: var(--color-primary-dark);">Buscar</h1>
    <form action="{{ routes.search_url }}" method="get" style="margin-bottom:2rem;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Buscar productos…" style="width:100%; padding:1rem; border:1.5px solid var(--color-border); border-radius:var(--radius-pill); font-size:1rem;">
    </form>

    {%- if search.performed -%}
      <p style="color: var(--color-text-muted);">{{ search.results_count }} resultados para "{{ search.terms }}"</p>
      <div style="display:grid; gap:1.25rem; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Búsqueda",
  "settings": []
}
{% endschema %}
