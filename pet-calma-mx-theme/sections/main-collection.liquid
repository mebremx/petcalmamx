<section class="section">
  <div class="container">
    <header style="text-align:center; margin-bottom:2rem;">
      <h1 style="color: var(--color-primary-dark);">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p style="color: var(--color-text-muted);">{{ collection.description }}</p>
      {%- endif -%}
    </header>

    <div style="display:grid; gap:1.25rem; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p>No hay productos en esta colección.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Colección",
  "settings": []
}
{% endschema %}
