<section class="section section--cream faq">
  <div class="container">
    <header class="benefits__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.title }}</h2>
    </header>

    <div class="faq__list">
      {%- for block in section.blocks -%}
        <details class="faq-item" {{ block.shopify_attributes }}{% if forloop.first %} open{% endif %}>
          <summary>{{ block.settings.question }}</summary>
          <div class="faq-item__answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "Preguntas frecuentes" },
    { "type": "text", "id": "title", "label": "Título", "default": "Resuelve tus dudas" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        { "type": "text", "id": "question", "label": "Pregunta", "default": "¿Pregunta?" },
        { "type": "textarea", "id": "answer", "label": "Respuesta", "default": "Respuesta detallada." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "¿Es seguro para mi mascota?", "answer": "Sí. Está hecho 100% de silicona de grado alimenticio, libre de BPA y materiales tóxicos. Es el mismo material usado en utensilios de cocina para bebés." } },
        { "type": "faq", "settings": { "question": "¿Para qué mascotas funciona?", "answer": "Para perros y gatos de todos los tamaños. Es especialmente útil con mascotas ansiosas, cachorros, perros que odian bañarse o gatos que arañan muebles por aburrimiento." } },
        { "type": "faq", "settings": { "question": "¿Cómo se limpia?", "answer": "Muy fácil. Puedes lavarlo con agua y jabón, o meterlo al lavavajillas. Las cerdas de silicona no retienen olores ni bacterias." } },
        { "type": "faq", "settings": { "question": "¿Qué le pongo encima?", "answer": "Crema de cacahuate sin xilitol, paté para perros, yogurt natural sin azúcar, comida húmeda, plátano machacado o cualquier alimento blando que tu mascota disfrute." } },
        { "type": "faq", "settings": { "question": "¿Cuánto tarda el envío?", "answer": "Enviamos en 24-48 horas hábiles desde nuestro almacén. La entrega tarda 3-5 días hábiles a toda la República Mexicana. Envío gratis en compras mayores a $499 MXN." } },
        { "type": "faq", "settings": { "question": "¿Tiene garantía?", "answer": "Sí. Ofrecemos garantía de satisfacción de 30 días. Si tu mascota no lo ama, te devolvemos tu dinero." } }
      ]
    }
  ]
}
{% endschema %}
