<section class="section section--white social-proof">
  <div class="container">
    <header class="benefits__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.title }}</h2>
    </header>

    {%- if section.settings.show_stats -%}
      <div class="social__stats">
        <div>
          <span class="stat__num">{{ section.settings.stat_1_num }}</span>
          <span class="stat__label">{{ section.settings.stat_1_label }}</span>
        </div>
        <div>
          <span class="stat__num">{{ section.settings.stat_2_num }}</span>
          <span class="stat__label">{{ section.settings.stat_2_label }}</span>
        </div>
        <div>
          <span class="stat__num">{{ section.settings.stat_3_num }}</span>
          <span class="stat__label">{{ section.settings.stat_3_label }}</span>
        </div>
      </div>
    {%- endif -%}

    <div class="testimonials">
      {%- for block in section.blocks -%}
        <article class="testimonial" {{ block.shopify_attributes }}>
          <div class="testimonial__stars" aria-label="5 estrellas">★★★★★</div>
          <p class="testimonial__text">"{{ block.settings.text }}"</p>
          <div class="testimonial__author">
            <span class="testimonial__avatar">
              {%- if block.settings.avatar != blank -%}
                {{ block.settings.avatar | image_url: width: 80 | image_tag: loading: 'lazy', alt: block.settings.name }}
              {%- else -%}
                {{ block.settings.name | slice: 0, 1 | upcase }}
              {%- endif -%}
            </span>
            <div>
              <div class="testimonial__name">{{ block.settings.name }}</div>
              <div class="testimonial__meta">{{ block.settings.meta }}</div>
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Prueba social",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "Lo que dicen nuestros clientes" },
    { "type": "text", "id": "title", "label": "Título", "default": "+1,200 mascotas más felices" },
    { "type": "checkbox", "id": "show_stats", "label": "Mostrar estadísticas", "default": true },
    { "type": "text", "id": "stat_1_num", "label": "Stat 1 número", "default": "1,200+" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 texto", "default": "Mascotas felices" },
    { "type": "text", "id": "stat_2_num", "label": "Stat 2 número", "default": "4.9★" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 texto", "default": "Calificación promedio" },
    { "type": "text", "id": "stat_3_num", "label": "Stat 3 número", "default": "30 días" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 texto", "default": "De garantía" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Testimonio", "default": "Mi perrita odiaba bañarse. Le pego el tapete con crema de cacahuate y se queda super tranquila. Cambió todo." },
        { "type": "text", "id": "name", "label": "Nombre", "default": "María L." },
        { "type": "text", "id": "meta", "label": "Detalle", "default": "CDMX · Dueña de Luna 🐶" },
        { "type": "image_picker", "id": "avatar", "label": "Foto (opcional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Prueba social",
      "blocks": [
        { "type": "testimonial", "settings": { "text": "Mi perrita odiaba bañarse. Le pego el tapete con crema de cacahuate y se queda super tranquila. Cambió todo.", "name": "María L.", "meta": "CDMX · Dueña de Luna 🐶" } },
        { "type": "testimonial", "settings": { "text": "Compré uno para mi gata ansiosa. Ahora lo usa todos los días con paté y dejó de arañar el sillón. Vale cada peso.", "name": "Andrea G.", "meta": "Guadalajara · Dueña de Mishi 🐱" } },
        { "type": "testimonial", "settings": { "text": "El corte de uñas era una tortura. Con el lick mat le pongo yogurt y termina antes de que termine. Recomendadísimo.", "name": "Diego R.", "meta": "Monterrey · Papá de Toby 🐶" } }
      ]
    }
  ]
}
{% endschema %}
